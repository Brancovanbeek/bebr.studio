---
import SanityImg from "@otterstack/sanity-img-astro"
const { blog } = Astro.props
---

<article class="blog-card">
  <SanityImg
    src={blog.image}
    sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
    alt={blog.heading}
    class="blog-card_image"
  />
  <section class="blog-card_content">
    <p class="blog-card_category heading-xs">{blog.category}</p>
    <h3 class="blog-card_heading heading-m">{blog.heading}</h3>
  </section>
</article>

<style>
  .blog-card_image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .blog-card_heading{
    color: var(--color-primary);
  }

  .blog-card_category{
    color: var(--color-gray-700);
    font-weight: var(--font-weight-medium);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }
</style>