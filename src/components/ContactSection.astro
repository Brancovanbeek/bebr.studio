---
import { client } from '../lib/sanity'

const { heading, tagline, Email, social, office, formSettings } = await client.fetch(`
  *[_type == "homePage"][0].sections[_type == "contactSection"][0]{
    heading,
    tagline,
    Email,
    social,
    office,
    formSettings
  }
`)
---

<section class="contact-section">
  <div class="contact-header">
    <h2 class="heading-xl">{heading}</h2>
    <p class="heading-m">{tagline}</p>
  </div>

  <div class="contact-body">

    <div class="contact-info">
      <div class="info-block">
        <h3 class="heading-xs">{office.label}</h3>
        <p class="heading-xs">{office.address}</p>
      </div>

      <div class="info-block">
        <a href={`mailto:${Email.email}`} class="email-link heading-xs">
          {Email.emailLinkText}
        </a>
      </div>

      <div class="info-block">
        <h3 class="heading-xs">{social.label}</h3>
        {social?.links?.map((link: { url: string; platform: string }) => (
          <a href={link.url} class="link heading-xs" target="_blank" rel="noopener noreferrer">
            {link.platform}
          </a>
        ))}
      </div>
    </div>

    <form id="contact-form" class="contact-form">
      <div class="form-row">
        <div class="form-group">
          <label class="heading-xs">First name*</label>
          <input class="heading-xs" type="text" name="firstName" placeholder="First name" required />
        </div>
        <div class="form-group">
          <label class="heading-xs">Last name*</label>
          <input class="heading-xs" type="text" name="lastName" placeholder="Last name" required />
        </div>
      </div>

      <div class="form-group">
        <label class="heading-xs">Email address*</label>
        <input class="heading-xs" type="email" name="email" placeholder="Email address" required />
      </div>

      <div class="form-group">
        <label class="heading-xs">Vertel ons wat je in gedachten hebt</label>
        <textarea class="heading-xs" name="message" placeholder="Vertel ons wat je in gedachten hebt"></textarea>
      </div>

      <button class="heading-xs" type="submit">{formSettings.submitButtonText}</button>

      <p id="form-message" class="muted"></p>
    </form>

  </div>
</section>

<script is:inline>
  const API_ENDPOINT = '/api/contact'

  function getFormData(form) {
    return {
      firstName: form.firstName.value,
      lastName: form.lastName.value,
      email: form.email.value,
      message: form.message.value,
    }
  }

  async function submitForm(data) {
    const res = await fetch(API_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    })
    return res.json()
  }

  function showMessage(element, text) {
    element.textContent = text
  }

  const form = document.getElementById('contact-form')
  const messageEl = document.getElementById('form-message')

  form.addEventListener('submit', async (e) => {
    e.preventDefault()

    try {
      const result = await submitForm(getFormData(form))

      if (result.success) {
        showMessage(messageEl, 'Bericht verstuurd!')
        form.reset()
      } else {
        showMessage(messageEl, 'Er ging iets mis, probeer opnieuw.')
      }
    } catch (err) {
      showMessage(messageEl, 'Server fout.')
    }
  })
</script>

<style>
  .contact-section {
    padding: var(--space-8);
    background: var(--color-background);
    margin-block: var(--space-8);
  }

  .contact-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-12);
  }

  .contact-header h2 {
    color: var(--color-primary);
  }

  .contact-header p {
    color: var(--color-primary);
    max-width: 500px;
    text-align: right;
  }

  .contact-body {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-8);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);

  }
  
  .info-block {
    display: flex;
    flex-direction: column;
    width: fit-content;
    p {
      color: var(--color-gray-500);
      white-space: pre-line;
    }
  }

  .link {
    color: var(--color-gray-500);
  }

  .info-block h3 {
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .email-link {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    width: fit-content;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    color: var(--color-primary);
  }

  .form-group input,
  .form-group textarea {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--border-radius-md);
    padding: var(--space-4);
    font-size: var(--font-size-body);
    font-family: var(--font-primary);
    color: var(--color-primary);
    outline: none;
    width: 100%;
    background: var(--color-background);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-gray-500);
  }

  .form-group textarea {
    resize: none;
    height: 160px;
  }

  button[type="submit"] {
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 999px;
    padding: var(--space-4) var(--space-12);
    font-size: var(--font-size-body);
    font-family: var(--font-primary);
    width: fit-content;
  }

  @media (max-width: 600px) {
    .contact-section {
      padding: var(--space-6);
    }

    .contact-header {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
      margin-bottom: var(--space-8);
    }

    .contact-header p {
      text-align: left;
      max-width: 100%;
    }

    .contact-body {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .contact-info {
      gap: var(--space-6);
    }

    .form-row {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    button {
      margin: 0 auto;
    }
  }
</style>