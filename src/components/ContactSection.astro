---
import { client } from '../lib/sanity'

const { heading, tagline, Email, social, office, formSettings } = await client.fetch(`
  *[_type == "homePage"][0].sections[_type == "contactSection"][0]{
    heading,
    tagline,
    Email,
    social,
    office,
    formSettings
  }
`)

const url = new URL(Astro.request.url)
const status = url.searchParams.get('success')
---

<section id="contact-section" class="contact-section container">
  <div class="contact-header">
    <h2 class="heading-xl">{heading}</h2>
    <p class="heading-m">{tagline}</p>
  </div>

  <div class="contact-body">

    <div class="contact-info">
      <div class="info-block">
        <h3 class="heading-xs">{office.label}</h3>
        <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(office.address)}`}
          class="link heading-xs"
          target="_blank"
          rel="noopener noreferrer"
        >
          {office.address}
        </a>
      </div>

      <div class="info-block">
        <a href={`mailto:${Email.email}`} class="email-link heading-xs">
          {Email.emailLinkText}
        </a>
      </div>

      <div class="info-block">
        <h3 class="heading-xs">{social.label}</h3>
        {social?.links?.map((link: { url: string; platform: string }) => (
          <a href={link.url} class="link heading-xs" target="_blank" rel="noopener noreferrer">
            {link.platform}
          </a>
        ))}
      </div>
    </div>

    <form id="contact-form" class="contact-form" action="/api/contact" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label class="heading-xs" for="firstName">Voornaam*</label>
          <input class="heading-xs" type="text" name="firstName" placeholder="Voornaam" required />
        </div>
        <div class="form-group">
          <label class="heading-xs" for="lastName">Achternaam*</label>
          <input class="heading-xs" type="text" name="lastName" placeholder="Achternaam" required />
        </div>
      </div>

      <div class="form-group">
        <label class="heading-xs" for="email">Email*</label>
        <input class="heading-xs" type="email" name="email" placeholder="Email" required />
      </div>

      <div class="form-group">
        <label class="heading-xs" for="message">Wat kunnen wij voor jou betekenen?</label>
        <textarea class="heading-xs" name="message" placeholder="Vertel ons wat je in gedachten hebt"></textarea>
      </div>

      <button class="heading-xs" type="submit" id="submit-btn">
        <span id="btn-text">{formSettings.submitButtonText}</span>
        <span id="btn-spinner" style="display:none">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
          </svg>
        </span>
      </button>

      <p id="form-message" class="muted"></p>
    </form>

  </div>
</section>

<script is:inline>
  const API_ENDPOINT = '/api/contact'

  const form = document.getElementById('contact-form')
  const btn = document.getElementById('submit-btn')
  const btnText = document.getElementById('btn-text')
  const btnSpinner = document.getElementById('btn-spinner')

  function setLoading(on) {
    btnText.style.display = on ? 'none' : 'inline'
    btnSpinner.style.display = on ? 'inline-flex' : 'none'
    btn.disabled = on
  }

  function setSuccess() {
    btnText.textContent = 'Verstuurd'
    btnText.style.display = 'inline'
    btnSpinner.style.display = 'none'
    btn.style.background = 'transparent'
    btn.style.color = 'var(--color-primary)'
    btn.style.border = 'var(--border-width) solid var(--color-primary)'
    btn.disabled = true
  }

  function setError() {
    btnText.textContent = 'Probeer opnieuw'
    btnText.style.display = 'inline'
    btnSpinner.style.display = 'none'
    btn.disabled = false
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    setLoading(true)

    try {
      const res = await fetch(API_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName: form.firstName.value,
          lastName: form.lastName.value,
          email: form.email.value,
          message: form.message.value,
        }),
      })
      const result = await res.json()

      if (result.success) {
        setSuccess()
        form.reset()
      } else {
        setError()
      }
    } catch (err) {
      setError()
    }
  })
</script>

<style>
  .contact-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-12);
  }

  .contact-header h2 {
    color: var(--color-primary);
    &::before,
    &::after {
      content: none;
    }
  }

  .contact-header p {
    color: var(--color-primary);
    max-width: 500px;
    text-align: right;
  }

  .contact-body {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-8);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);

  }
  
  .info-block {
    display: flex;
    flex-direction: column;
    width: fit-content;
    p {
      color: var(--color-gray-500);
      white-space: pre-line;
    }
  }

  .link {
    color: var(--color-gray-700);
    white-space: pre-line;
  }

  .info-block h3 {
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .email-link {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    width: fit-content;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    color: var(--color-primary);
  }

  .form-group input,
  .form-group textarea {
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--border-radius-md);
    padding: var(--space-4);
    font-size: var(--font-size-body);
    font-family: var(--font-primary);
    color: var(--color-primary);
    outline: none;
    width: 100%;
    background: var(--color-background);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-gray-500);
  }

  .form-group textarea {
    resize: none;
    height: 160px;
  }

  button[type="submit"] {
    background: var(--color-primary);
    border-radius: 999px;
    padding: var(--space-4) var(--space-12);
    font-size: var(--font-size-body);
    font-family: var(--font-primary);
    width: fit-content;
    width: 140px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #btn-spinner svg {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (max-width: 600px) {
    .contact-header {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
      margin-bottom: var(--space-8);
    }

    .contact-header p {
      text-align: left;
      max-width: 100%;
    }

    .contact-body {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .contact-info {
      gap: var(--space-6);
    }

    .form-row {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    button {
      margin: 0 auto;
    }
  }
</style>