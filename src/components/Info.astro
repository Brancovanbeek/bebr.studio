---
import { client } from '../lib/sanity'

const { info } = await client.fetch(`
  *[_type == "homePage"][0]{
    "info": sections[_type == "infoSection"][0]{
      introParagraphs,
      valuesLabel,
      values[]{
        title,
        description
      },
      backgroundColor
    }
  }
`)
---

<section class="info-section">
  <div class="info-container">
    <!-- Intro Paragraphs -->
    <div class="intro-content">
      {info?.introParagraphs?.map((paragraph: string) => (
        <h2 class="intro-text heading-m">{paragraph}</h2>
      ))}

      <div class="line"></div>
    </div>

    <!-- Values Label -->
    <div class="values-label-column">
      {info?.valuesLabel && (
        <h2 class="values-label heading-xs">{info.valuesLabel}</h2>
      )}
    </div>

    <!-- Values Grid -->
    <div class="values-column">
      {info?.values?.map((value: any) => (
        <div class="value-item">
          <h3 class="value-title heading-xs">{value.title}</h3>
          <p class="value-description heading-xs">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.info-section {
  background-color: var(--color-black);
  color: var(--color-white);
  padding: var(--space-8);
  padding-block: var(--space-24);
}

.info-container {
  max-width: 1440px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-12);
  margin-bottom: var(--space-4);
}

.intro-content {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);

  :nth-child(2) {
    margin-bottom: var(--space-12);
  }
}

.intro-text {
  line-height: var(--line-height-relaxed);
  font-weight: var(--font-weight-medium);
  max-width: 40ch;
}

.line {
  width: 100%;
  height: 1px;
  background-color: var(--color-gray-900);
}

.values-label-column {
  grid-column: 1 / -1;
}

.values-label {
  font-weight: var(--font-weight-medium);
}

.values-column {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.value-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.value-title {
  font-weight: var(--font-weight-medium);
}

.value-description {
  line-height: var(--line-height-relaxed);
  color: var(--color-gray-500);
  opacity: 0.8;
  max-width: 40ch;
}

/* Desktop */
@media (min-width: 768px) {
  .info-section {
    padding: var(--space-8);
    padding-block: var(--space-24);
  }

  .info-container {
    grid-template-columns: 1fr 1fr;
  }

  .intro-content {
    grid-column: 1 / -1;
  }

  .values-label-column {
    grid-column: 1;
  }

  .values-column {
    grid-column: 2;
    gap: var(--space-12);
  }
}

@media (min-width: 1024px) {
  .info-section {
    padding: var(--space-8);
    padding-block: var(--space-24);
  }
}
</style>