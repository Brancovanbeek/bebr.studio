---
import { client } from '../lib/sanity'

const { info } = await client.fetch(`
  *[_type == "homePage"][0]{
    "info": sections[_type == "infoSection"][0]{
      introParagraphs,
      valuesLabel,
      values[]{
        title,
        description
      }
    }
  }
`)
---

<section class="info-section">
  <div class="info-container">
    <!-- Intro Paragraphs -->
    <div class="intro-content">
      {info?.introParagraphs?.map((paragraph: string) => (
        <p class="intro-text body-l">{paragraph}</p>
      ))}
    </div>

    <!-- Values Label -->
    <div class="values-label-column">
      {info?.valuesLabel && (
        <p class="values-label body-s">{info.valuesLabel}</p>
      )}
    </div>

    <!-- Values Grid -->
    <div class="values-column">
      {info?.values?.map((value: any) => (
        <div class="value-item">
          <h3 class="value-title heading-l">{value.title}</h3>
          <p class="value-description body-m">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.info-section {
  background-color: var(--color-black);
  color: var(--color-white);
  padding: var(--space-8);
}

.info-container {
  max-width: 1440px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-12);
}

.intro-content {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.values-label-column {
  grid-column: 1 / -1;
}

.values-column {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.value-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* Desktop */
@media (min-width: 768px) {
  .info-container {
    grid-template-columns: 1fr 1fr;
  }

  .intro-content {
    grid-column: 1 / -1;
  }

  .values-label-column {
    grid-column: 1;
  }

  .values-column {
    grid-column: 2;
    gap: var(--space-12);
  }
}

.intro-text {
  line-height: var(--line-height-relaxed);
  font-size: var(--font-size-heading-s);
  max-width: 40ch;
}

.values-label {
  font-weight: var(--font-weight-medium);
}

.value-title {
  font-weight: var(--font-weight-medium);
  font-size: var(--font-size-body);
}

.value-description {
  line-height: var(--line-height-relaxed);
  opacity: 0.8;
  max-width: 40ch;
}
</style>