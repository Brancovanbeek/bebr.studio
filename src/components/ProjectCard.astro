---
import SanityImg from "@otterstack/sanity-img-astro"
const { project } = Astro.props
---

<article class="project-card">
  <SanityImg
    src={project.image}
    sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
    alt={project.heading}
    class="project-card-image"
  />
  <section class="project-card-content">
    <p class="project-card-category heading-xs">{project.category}</p>
    <h3 class="project-card-heading heading-m">{project.heading}</h3>
  </section>
</article>

<style>
.project-card-image {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
}

h3{
    color: var(--color-primary);
    line-height: var(--line-height-tight);
}

p{
    color: var(--color-text-muted);
    font-weight: var(--font-weight-medium);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
}
</style>