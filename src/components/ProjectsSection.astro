---
import { client } from '../lib/sanity'
import ProjectCard from './ProjectCard.astro'

const { projects } = await client.fetch(`
  *[_type == "homePage"][0]{
    "projects": sections[_type == "projectSection"][0].projects
  }
`)
---

<section class="project-wrapper container">
  <section class="project-header">
    <h2 class="section-label heading-xs">(Projecten)</h2>
    <p class="section-description heading-m">Een selectie van onze <br> nieuwste projecten</p>
  </section>

  <section class="project-section">
    {projects?.map((project: any) => (
      <ProjectCard project={project} />
    ))}
  </section>
</section>

<style>
.project-header {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--space-6);
}

.section-label{
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.section-description {
  color: var(--color-primary);
  display: none;
  margin-left: auto;
}

.project-section {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--grid-gap);
}

@media (min-width: 768px) {
  .project-section {
    grid-template-columns: repeat(2, 1fr);
  }
  .section-label {
  align-self: center;
  }
  .project-header {
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: var(--space-12);
  }
  .section-description {
    display: block;
  }
}

@media (min-width: 1024px) {
  .project-section {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>