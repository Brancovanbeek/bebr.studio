---
// TeamCard.astro
import SanityImg from "@otterstack/sanity-img-astro"
const { member } = Astro.props
---

<article class="team-card">
    <div class="team-card_image-wrapper">
        <SanityImg
        src={member.image}
        sizes="(min-width: 1024px) 33vw, 50vw"
        alt={`Photo of ${member.name}`}
        class="team-card_image"
        />
    </div>
    <section class="team-card_content">
        <h4 class="member-name heading-xs">{member.name}</h4>
        <p class="member-role heading-xs">{member.role}</p>
    </section>
</article>

<style>
    .team-card_image-wrapper {
        aspect-ratio: 3 / 4;
        overflow: hidden;
    }

    .team-card_image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .team-card_content {
        display: flex;
        flex-direction: column;

        h4{
            margin-top: var(--space-2);
            color: var(--color-primary);
            font-weight: var(--font-weight-medium);
        }

        p{
            color: var(--color-gray-500);
        }
    }

    .member-name {
        font-weight: bold;
    }


</style>